NODE_ENV=production
PORT=4300
SESSION_SECRET=change-this-to-a-long-random-production-secret

# HOSxP / HOSxP XE MySQL defaults.
# Admin can override these from the Database Settings page.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hos
DB_CONNECTION_LIMIT=10

# Default accounts for first run. Change the password after login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
EXECUTIVE_USERNAME=
EXECUTIVE_PASSWORD=
EXECUTIVE_NAME=Executive
USER_USERNAME=
USER_PASSWORD=
USER_NAME=User

HOSPCODE=11202
DEBUG_SQL=false
ENABLE_HSTS=false
ENABLE_HTTPS_UPGRADE=false

PORT=4300
SESSION_SECRET=change-this-long-random-secret

# HOSxP / HOSxP XE MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hos
DB_CONNECTION_LIMIT=10

# Seed admin user for first run. Change after login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# Optional accounts
EXECUTIVE_USERNAME=
EXECUTIVE_PASSWORD=
EXECUTIVE_NAME=ผู้บริหาร
USER_USERNAME=
USER_PASSWORD=
USER_NAME=ผู้ใช้งาน

HOSPCODE=11202

# Optional: set to true only if you want detailed SQL errors in server logs.
DEBUG_SQL=false

<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Telemed Dashboard</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>">
</head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar', { active: 'today-patients' }) %>

    <main class="main today-patients-page">
      <header class="topbar">
        <div>
          <p class="eyebrow">ภาพรวมบริการโรงพยาบาล</p>
          <h1>ภาพรวมผู้รับบริการวันนี้</h1>
          <p class="page-description">แสดงจำนวนผู้รับบริการของโรงพยาบาลจากระบบ HOSxP แบบใกล้เคียงเรียลไทม์</p>
        </div>
        <% if (currentUser) { %>
          <form action="/logout" method="post" class="user-box">
            <span><i class="bi bi-person-circle"></i> <%= currentUser.name %></span>
            <button type="submit" class="icon-button" title="ออกจากระบบ" aria-label="ออกจากระบบ">
              <i class="bi bi-box-arrow-right"></i>
            </button>
          </form>
        <% } %>
      </header>

      <section class="panel today-status-panel" aria-live="polite">
        <div class="today-status-content">
          <p id="todayDataDate" class="today-date-label">กำลังโหลดข้อมูลประจำวัน</p>
          <div class="today-status-line">
            <span id="todayDbStatus" class="connection-pill pending">
              <i class="bi bi-circle-fill"></i>
              กำลังเชื่อมต่อ HOSxP
            </span>
            <span id="todayLastUpdated" class="today-status-meta">อัปเดตล่าสุด -</span>
          </div>
          <p id="todayStatusMessage" class="dashboard-status loading">กำลังดึงข้อมูลล่าสุด...</p>
        </div>
        <div class="today-status-actions">
          <button type="button" id="todayRefreshButton" class="primary-button today-refresh-button">
            <i class="bi bi-arrow-clockwise"></i>
            รีเฟรชข้อมูล
          </button>
          <span class="today-refresh-note"><i class="bi bi-hand-index-thumb"></i> กดรีเฟรชเพื่ออัปเดตข้อมูลล่าสุด</span>
        </div>
      </section>

      <section class="today-card-grid" aria-label="ยอดผู้รับบริการวันนี้">
        <article class="today-card opd">
          <span class="today-card-icon"><i class="bi bi-hospital"></i></span>
          <div class="today-card-content">
            <p>ผู้ป่วยนอก OPD</p>
            <div class="today-card-metric">
              <strong data-today-value="opd_total">-</strong>
              <span>คน</span>
            </div>
          </div>
        </article>
        <article class="today-card ncd clickable" id="ncdSubclinicCard" role="button" tabindex="0" aria-haspopup="dialog" aria-controls="ncdSubclinicModal">
          <span class="today-card-icon"><i class="bi bi-heart-pulse"></i></span>
          <div class="today-card-content">
            <p>งาน NCD</p>
            <div class="today-card-metric">
              <strong data-today-value="ncd_total">-</strong>
              <span>คน</span>
            </div>
            <small class="today-card-action">คลิกดูคลินิกย่อย</small>
          </div>
        </article>
        <article class="today-card ipd">
          <span class="today-card-icon"><i class="bi bi-building"></i></span>
          <div class="today-card-content">
            <p>ผู้ป่วยใน IPD</p>
            <div class="today-card-metric">
              <strong data-today-value="ipd_total">-</strong>
              <span>คน</span>
            </div>
            <small>กำลังนอนรักษา</small>
          </div>
        </article>
        <article class="today-card er">
          <span class="today-card-icon"><i class="bi bi-lightning-charge"></i></span>
          <div class="today-card-content">
            <p>อุบัติเหตุฉุกเฉิน ER</p>
            <div class="today-card-metric">
              <strong data-today-value="er_total">-</strong>
              <span>คน</span>
            </div>
          </div>
        </article>
      </section>
    </main>
  </div>

  <div id="ncdSubclinicModal" class="modal-backdrop ncd-subclinic-modal hidden" aria-hidden="true">
    <div class="modal-dialog ncd-subclinic-dialog" role="dialog" aria-modal="true" aria-labelledby="ncdSubclinicTitle">
      <div class="modal-heading">
        <div>
          <p class="eyebrow">ผู้รับบริการวันนี้</p>
          <h2 id="ncdSubclinicTitle">คลินิกย่อย NCD วันนี้</h2>
          <p class="panel-note">แสดงยอดผู้รับบริการตามห้องที่ตั้งค่าไว้ในแต่ละคลินิก</p>
        </div>
        <button type="button" class="icon-button" id="ncdSubclinicCloseButton" aria-label="ปิดหน้าต่างคลินิกย่อย NCD">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>

      <div id="ncdSubclinicStatus" class="dashboard-status loading">กำลังโหลดข้อมูลคลินิกย่อย...</div>
      <div id="ncdSubclinicGrid" class="ncd-subclinic-grid" aria-live="polite"></div>

      <div id="ncdSubclinicNote" class="alert warning ncd-subclinic-note hidden">
        หมายเหตุ: ยอดรวมคลินิกย่อยอาจไม่เท่ากับยอด NCD หลัก หากการตั้งค่าห้องยังไม่ครบ
      </div>

      <div class="ncd-subclinic-footer">
        <div>
          <strong id="ncdSubclinicTotal">รวมคลินิกย่อย NCD วันนี้: - คน</strong>
          <span id="ncdSubclinicUpdated">อัปเดตล่าสุด -</span>
        </div>
        <div class="modal-actions">
          <% if (currentUser && currentUser.role === 'admin') { %>
            <a class="secondary-button" href="/admin/ncd-subclinics">
              <i class="bi bi-gear"></i>
              ตั้งค่าคลินิกย่อย
            </a>
          <% } %>
          <button type="button" class="primary-button" id="ncdSubclinicCancelButton">ปิด</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/today-patients.js?v=<%= assetVersion %>"></script>
</body>
</html>

<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Telemed Dashboard</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <a class="brand" href="/telemed">
        <span class="brand-mark"><i class="bi bi-heart-pulse"></i></span>
        <span>
          <strong>Telemed</strong>
          <small>Hospital Dashboard</small>
        </span>
      </a>
      <nav class="nav-menu" aria-label="เมนูหลัก">
        <a class="nav-link" href="/telemed">
          <i class="bi bi-grid-1x2"></i>
          <span>Telemed Dashboard</span>
        </a>
        <a class="nav-link" href="/executive">
          <i class="bi bi-bar-chart-line"></i>
          <span>Executive Dashboard</span>
        </a>
        <div class="nav-section">Admin</div>
        <a class="nav-link active" href="/settings">
          <i class="bi bi-database-gear"></i>
          <span>ตั้งค่าฐานข้อมูล</span>
        </a>
        <a class="nav-link" href="/admin/query-tool">
          <i class="bi bi-terminal"></i>
          <span>Query Tool</span>
        </a>
      </nav>
    </aside>

    <main class="main">
      <header class="topbar">
        <div>
          <p class="eyebrow">ผู้ดูแลระบบ</p>
          <h1><%= title %></h1>
        </div>
        <% if (currentUser) { %>
          <form action="/logout" method="post" class="user-box">
            <span><i class="bi bi-person-circle"></i> <%= currentUser.name %></span>
            <button type="submit" class="icon-button" title="ออกจากระบบ" aria-label="ออกจากระบบ">
              <i class="bi bi-box-arrow-right"></i>
            </button>
          </form>
        <% } %>
      </header>

      <section class="panel settings-panel">
        <div class="panel-heading">
          <div>
            <h2>เชื่อมต่อฐานข้อมูล HOSxP / HOSxP XE</h2>
            <p class="panel-note">รหัสผ่านจะไม่ถูกแสดงกลับบนหน้าจอ ถ้าไม่ต้องการเปลี่ยนรหัสผ่านให้เว้นช่องนี้ไว้</p>
          </div>
          <span><i class="bi bi-shield-lock"></i> Admin only</span>
        </div>

        <% if (status) { %>
          <div class="alert success"><%= status %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <form method="post" action="/settings" class="settings-form">
          <div class="settings-grid">
            <label>
              Host / IP
              <input type="text" name="host" value="<%= config.host || '' %>" placeholder="127.0.0.1" required>
            </label>
            <label>
              Port
              <input type="number" name="port" value="<%= config.port || 3306 %>" min="1" max="65535" required>
            </label>
            <label>
              Database
              <input type="text" name="database" value="<%= config.database || '' %>" placeholder="hos" required>
            </label>
            <label>
              Connection limit
              <input type="number" name="connectionLimit" value="<%= config.connectionLimit || 10 %>" min="1" max="50" required>
            </label>
            <label>
              User
              <input type="text" name="user" value="<%= config.user || '' %>" autocomplete="off" required>
            </label>
            <label>
              Password
              <input type="password" name="password" value="" autocomplete="new-password" placeholder="<%= config.hasPassword ? 'มีรหัสผ่านเดิมแล้ว' : 'ไม่มีรหัสผ่าน' %>">
            </label>
          </div>

          <div class="settings-actions">
            <button type="submit" formaction="/settings/test" class="secondary-button">
              <i class="bi bi-plug"></i>
              ทดสอบการเชื่อมต่อ
            </button>
            <button type="submit" class="primary-button">
              <i class="bi bi-save"></i>
              บันทึกการตั้งค่า
            </button>
          </div>
        </form>
      </section>
    </main>
  </div>
</body>
</html>

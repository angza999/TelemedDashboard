<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Telemed Dashboard</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <a class="brand" href="/telemed">
        <span class="brand-mark"><i class="bi bi-heart-pulse"></i></span>
        <span>
          <strong>Telemed</strong>
          <small>Hospital Dashboard</small>
        </span>
      </a>
      <nav class="nav-menu" aria-label="เมนูหลัก">
        <a class="nav-link" href="/telemed">
          <i class="bi bi-grid-1x2"></i>
          <span>Telemed Dashboard</span>
        </a>
        <a class="nav-link" href="/executive">
          <i class="bi bi-bar-chart-line"></i>
          <span>Executive Dashboard</span>
        </a>
        <div class="nav-section">Admin</div>
        <a class="nav-link" href="/settings">
          <i class="bi bi-database-gear"></i>
          <span>ตั้งค่าฐานข้อมูล</span>
        </a>
        <a class="nav-link active" href="/admin/query-tool">
          <i class="bi bi-terminal"></i>
          <span>Query Tool</span>
        </a>
      </nav>
    </aside>

    <main class="main">
      <header class="topbar">
        <div>
          <p class="eyebrow">Admin</p>
          <h1>Query Tool</h1>
        </div>
        <% if (currentUser) { %>
          <form action="/logout" method="post" class="user-box">
            <span><i class="bi bi-person-circle"></i> <%= currentUser.name %></span>
            <button type="submit" class="icon-button" title="ออกจากระบบ" aria-label="ออกจากระบบ">
              <i class="bi bi-box-arrow-right"></i>
            </button>
          </form>
        <% } %>
      </header>

      <section class="panel query-panel">
        <div class="panel-heading">
          <div>
            <h2>ตรวจสอบข้อมูล Telemed ด้วย SQL</h2>
            <p class="panel-note">อนุญาตเฉพาะ SELECT และจำกัดผลลัพธ์สูงสุด 1000 rows</p>
          </div>
          <span><i class="bi bi-shield-lock"></i> Admin only</span>
        </div>

        <% if (status) { %>
          <div class="alert success"><%= status %></div>
        <% } %>
        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>
        <div class="alert warning">
          Query Tool นี้สำหรับผู้ดูแลระบบเท่านั้น หาก query มีชื่อผู้ป่วย เลขบัตรประชาชน หรือข้อมูลระบุตัวบุคคล กรุณาใช้อย่างระมัดระวังและไม่เผยแพร่ต่อ
        </div>

        <form method="post" action="/admin/query-tool/run" class="query-form">
          <label>
            SQL Query
            <textarea name="sql" rows="9" spellcheck="false" required><%= sql %></textarea>
          </label>
          <div class="settings-actions">
            <button type="submit" class="primary-button">
              <i class="bi bi-play-fill"></i>
              Run Query
            </button>
            <a class="secondary-button" href="/admin/query-tool/clear">
              <i class="bi bi-x-circle"></i>
              Clear
            </a>
            <% if (rowCount !== null) { %>
              <a class="secondary-button" href="/admin/query-tool/export.xlsx">
                <i class="bi bi-file-earmark-excel"></i>
                Export Excel
              </a>
            <% } %>
          </div>
        </form>
      </section>

      <% if (rowCount !== null) { %>
        <section class="panel table-panel">
          <div class="panel-heading">
            <h2>ผลลัพธ์</h2>
            <span><%= rowCount.toLocaleString('th-TH') %> rows</span>
          </div>
          <div class="table-wrap query-table-wrap">
            <table>
              <thead>
                <tr>
                  <% columns.forEach((column) => { %>
                    <th><%= column %></th>
                  <% }) %>
                </tr>
              </thead>
              <tbody>
                <% if (rows.length === 0) { %>
                  <tr><td colspan="<%= Math.max(columns.length, 1) %>" class="empty">ไม่พบข้อมูล</td></tr>
                <% } %>
                <% rows.forEach((row) => { %>
                  <tr>
                    <% columns.forEach((column) => { %>
                      <td><%= row[column] === null || row[column] === undefined ? '' : row[column] %></td>
                    <% }) %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>
    </main>
  </div>
</body>
</html>

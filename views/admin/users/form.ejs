<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Telemed Dashboard</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <div class="app-shell">
    <%- include('../../partials/sidebar', { active: 'users' }) %>

    <main class="main">
      <header class="topbar">
        <div>
          <p class="eyebrow">Admin</p>
          <h1><%= title %></h1>
        </div>
        <% if (currentUser) { %>
          <form action="/logout" method="post" class="user-box">
            <span><i class="bi bi-person-circle"></i> <%= currentUser.name %></span>
            <button type="submit" class="icon-button" title="ออกจากระบบ" aria-label="ออกจากระบบ">
              <i class="bi bi-box-arrow-right"></i>
            </button>
          </form>
        <% } %>
      </header>

      <section class="panel settings-panel">
        <div class="panel-heading">
          <div>
            <h2><%= title %></h2>
            <p class="panel-note">กำหนด username, ชื่อแสดงผล, role และสถานะการใช้งาน</p>
          </div>
          <span><i class="bi bi-shield-lock"></i> Admin only</span>
        </div>

        <% if (error) { %>
          <div class="alert"><%= error %></div>
        <% } %>

        <% const usernameLocked = mode === 'edit' && String(user.username || '').toLowerCase() === 'admin'; %>
        <form method="post" action="<%= mode === 'new' ? '/admin/users' : '/admin/users/' + user.id %>" class="settings-form">
          <div class="settings-grid">
            <label>
              Username
              <input type="text" name="username" value="<%= user.username %>" autocomplete="off" required <%= usernameLocked ? 'readonly aria-describedby="usernameHelp"' : '' %>>
              <small class="field-hint" id="usernameHelp">
                <%= usernameLocked ? 'ไม่สามารถเปลี่ยน username ของผู้ดูแลระบบหลักได้' : 'แก้ไขได้ แต่ต้องไม่ซ้ำกับผู้ใช้อื่น' %>
              </small>
            </label>
            <label>
              ชื่อแสดงผล
              <input type="text" name="name" value="<%= user.name %>" required>
            </label>
            <label>
              Role
              <select name="role" required>
                <% roles.forEach((role) => { %>
                  <option value="<%= role %>" <%= user.role === role ? 'selected' : '' %>><%= role %></option>
                <% }) %>
              </select>
            </label>
            <label class="checkbox-field">
              <input type="checkbox" name="isActive" <%= user.isActive ? 'checked' : '' %>>
              <span>Active</span>
            </label>
            <% if (mode === 'new') { %>
              <label>
                Password
                <input type="password" name="password" autocomplete="new-password" minlength="6" required>
              </label>
              <label>
                Confirm Password
                <input type="password" name="confirmPassword" autocomplete="new-password" minlength="6" required>
              </label>
            <% } %>
          </div>

          <div class="settings-actions">
            <a class="secondary-button" href="/admin/users">
              <i class="bi bi-arrow-left"></i>
              กลับ
            </a>
            <button type="submit" class="primary-button">
              <i class="bi bi-save"></i>
              บันทึก
            </button>
          </div>
        </form>
      </section>
    </main>
  </div>
</body>
</html>

<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Telemed Dashboard</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <div class="app-shell">
    <%- include('../../partials/sidebar', { active: 'users' }) %>

    <main class="main">
      <header class="topbar">
        <div>
          <p class="eyebrow">Admin</p>
          <h1><%= title %></h1>
        </div>
        <% if (currentUser) { %>
          <form action="/logout" method="post" class="user-box">
            <span><i class="bi bi-person-circle"></i> <%= currentUser.name %></span>
            <button type="submit" class="icon-button" title="ออกจากระบบ" aria-label="ออกจากระบบ">
              <i class="bi bi-box-arrow-right"></i>
            </button>
          </form>
        <% } %>
      </header>

      <section class="panel table-panel">
        <div class="panel-heading users-heading">
          <div>
            <h2>ผู้ใช้งานในระบบ</h2>
            <p class="panel-note">ทั้งหมด <%= users.length.toLocaleString('th-TH') %> บัญชี</p>
          </div>
          <div class="panel-actions">
            <span><i class="bi bi-shield-lock"></i> Admin only</span>
            <a class="primary-button" href="/admin/users/new">
              <i class="bi bi-person-plus"></i>
              เพิ่มผู้ใช้งาน
            </a>
          </div>
        </div>

        <% if (flash) { %>
          <div class="alert <%= flash.type === 'success' ? 'success' : '' %>"><%= flash.message %></div>
        <% } %>

        <div class="table-wrap user-table-wrap">
          <table>
            <thead>
              <tr>
                <th>Username</th>
                <th>ชื่อ</th>
                <th>Role</th>
                <th>สถานะ</th>
                <th>วันที่สร้าง</th>
                <th>แก้ไขล่าสุด</th>
                <th>จัดการ</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((user) => { %>
                <tr>
                  <td><%= user.username %></td>
                  <td><%= user.name %></td>
                  <td><span class="role-badge"><%= user.role %></span></td>
                  <td>
                    <span class="status-badge <%= user.isActive === false ? 'inactive' : 'active' %>">
                      <%= user.isActive === false ? 'Inactive' : 'Active' %>
                    </span>
                  </td>
                  <td><%= user.createdAt ? new Date(user.createdAt).toLocaleString('th-TH') : '-' %></td>
                  <td><%= user.updatedAt ? new Date(user.updatedAt).toLocaleString('th-TH') : '-' %></td>
                  <td>
                    <div class="row-actions">
                      <a class="secondary-button compact" href="/admin/users/<%= user.id %>/edit">
                        <i class="bi bi-pencil-square"></i>
                        แก้ไข
                      </a>
                      <a class="secondary-button compact" href="/admin/users/<%= user.id %>/reset-password">
                        <i class="bi bi-key"></i>
                        Reset Password
                      </a>
                      <form method="post" action="/admin/users/<%= user.id %>/toggle-active">
                        <button type="submit" class="secondary-button compact <%= user.isActive === false ? '' : 'danger' %>">
                          <i class="bi <%= user.isActive === false ? 'bi-toggle-on' : 'bi-toggle-off' %>"></i>
                          <%= user.isActive === false ? 'เปิดใช้งาน' : 'ปิดใช้งาน' %>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</body>
</html>

<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Telemed Dashboard</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <div class="app-shell">
    <%- include('../../partials/sidebar', { active: 'users' }) %>

    <main class="main">
      <header class="topbar">
        <div>
          <p class="eyebrow">Admin</p>
          <h1><%= title %></h1>
        </div>
        <% if (currentUser) { %>
          <form action="/logout" method="post" class="user-box">
            <span><i class="bi bi-person-circle"></i> <%= currentUser.name %></span>
            <button type="submit" class="icon-button" title="ออกจากระบบ" aria-label="ออกจากระบบ">
              <i class="bi bi-box-arrow-right"></i>
            </button>
          </form>
        <% } %>
      </header>

      <section class="panel table-panel">
        <% const adminCount = users.filter((user) => user.role === 'admin').length; %>
        <div class="panel-heading users-heading">
          <div>
            <h2>ผู้ใช้งานในระบบ</h2>
            <p class="panel-note">ทั้งหมด <span id="usersCount"><%= users.length.toLocaleString('th-TH') %></span> บัญชี</p>
          </div>
          <div class="panel-actions">
            <span><i class="bi bi-shield-lock"></i> Admin only</span>
            <a class="primary-button" href="/admin/users/new">
              <i class="bi bi-person-plus"></i>
              เพิ่มผู้ใช้งาน
            </a>
          </div>
        </div>

        <% if (flash) { %>
          <div class="alert <%= flash.type === 'success' ? 'success' : '' %>"><%= flash.message %></div>
        <% } %>
        <div id="usersNotice" class="alert hidden" role="status" aria-live="polite"></div>

        <div class="table-wrap user-table-wrap">
          <table>
            <thead>
              <tr>
                <th>Username</th>
                <th>ชื่อ</th>
                <th>Role</th>
                <th>สถานะ</th>
                <th>วันที่สร้าง</th>
                <th>แก้ไขล่าสุด</th>
                <th>จัดการ</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach((user) => { %>
                <%
                  const isMainAdmin = String(user.username || '').toLowerCase() === 'admin';
                  const isCurrentUser = currentUser && Number(currentUser.id) === Number(user.id);
                  const isLastAdmin = user.role === 'admin' && adminCount <= 1;
                  const deleteDisabled = isMainAdmin || isCurrentUser || isLastAdmin;
                  const deleteTitle = isMainAdmin
                    ? 'ไม่สามารถลบผู้ดูแลระบบหลักได้'
                    : (isCurrentUser
                      ? 'ไม่สามารถลบบัญชีที่กำลังใช้งานอยู่ได้'
                      : (isLastAdmin ? 'ไม่สามารถลบ admin คนสุดท้ายของระบบได้' : 'ลบผู้ใช้งาน'));
                %>
                <tr data-user-row="<%= user.id %>">
                  <td><%= user.username %></td>
                  <td><%= user.name %></td>
                  <td><span class="role-badge"><%= user.role %></span></td>
                  <td>
                    <span class="status-badge <%= user.isActive === false ? 'inactive' : 'active' %>">
                      <%= user.isActive === false ? 'Inactive' : 'Active' %>
                    </span>
                  </td>
                  <td><%= user.createdAt ? new Date(user.createdAt).toLocaleString('th-TH') : '-' %></td>
                  <td><%= user.updatedAt ? new Date(user.updatedAt).toLocaleString('th-TH') : '-' %></td>
                  <td>
                    <div class="row-actions">
                      <a class="secondary-button compact" href="/admin/users/<%= user.id %>/edit">
                        <i class="bi bi-pencil-square"></i>
                        แก้ไข
                      </a>
                      <a class="secondary-button compact" href="/admin/users/<%= user.id %>/reset-password">
                        <i class="bi bi-key"></i>
                        Reset Password
                      </a>
                      <form method="post" action="/admin/users/<%= user.id %>/toggle-active">
                        <button type="submit" class="secondary-button compact <%= user.isActive === false ? '' : 'danger' %>">
                          <i class="bi <%= user.isActive === false ? 'bi-toggle-on' : 'bi-toggle-off' %>"></i>
                          <%= user.isActive === false ? 'เปิดใช้งาน' : 'ปิดใช้งาน' %>
                        </button>
                      </form>
                      <button
                        type="button"
                        class="secondary-button compact danger delete-user-button"
                        data-user-id="<%= user.id %>"
                        data-username="<%= user.username %>"
                        title="<%= deleteTitle %>"
                        <%= deleteDisabled ? 'disabled' : '' %>
                      >
                        <i class="bi bi-trash"></i>
                        ลบ
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>

  <div id="deleteUserModal" class="modal-backdrop hidden" aria-hidden="true">
    <div class="modal-dialog danger-modal" role="dialog" aria-modal="true" aria-labelledby="deleteUserTitle">
      <div class="modal-heading">
        <div>
          <p class="eyebrow">Admin</p>
          <h2 id="deleteUserTitle">ยืนยันการลบผู้ใช้งาน</h2>
        </div>
        <button type="button" class="icon-button" id="deleteUserCloseButton" aria-label="ปิดหน้าต่างยืนยัน">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      <p class="modal-message">
        คุณต้องการลบผู้ใช้ “<strong id="deleteUserName">-</strong>” ใช่หรือไม่?<br>
        การลบนี้ไม่สามารถย้อนกลับได้
      </p>
      <div id="deleteUserError" class="alert hidden"></div>
      <div class="modal-actions">
        <button type="button" class="secondary-button" id="deleteUserCancelButton">ยกเลิก</button>
        <button type="button" class="primary-button danger-button" id="deleteUserConfirmButton">
          <i class="bi bi-trash"></i>
          ยืนยันลบผู้ใช้งาน
        </button>
      </div>
    </div>
  </div>

  <script src="/js/admin-users.js?v=<%= assetVersion %>"></script>
</body>
</html>

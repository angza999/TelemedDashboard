<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Telemed Dashboard</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar', { active: 'executive' }) %>

    <main class="main executive-main">
      <header class="topbar">
        <div>
          <p class="eyebrow">ภาพรวมสำหรับผู้บริหาร</p>
          <h1>Executive Dashboard</h1>
        </div>
        <% if (currentUser) { %>
          <form action="/logout" method="post" class="user-box">
            <span><i class="bi bi-person-circle"></i> <%= currentUser.name %></span>
            <button type="submit" class="icon-button" title="ออกจากระบบ" aria-label="ออกจากระบบ">
              <i class="bi bi-box-arrow-right"></i>
            </button>
          </form>
        <% } %>
      </header>

      <section class="filter-panel">
        <% if (dbError) { %>
          <div class="alert db-alert"><strong><%= dbError %></strong></div>
        <% } %>
        <form action="/executive" method="get" class="filter-grid executive-filter">
          <label>
            วันที่เริ่มต้น
            <input type="date" name="startDate" value="<%= filters.startDate %>">
          </label>
          <label>
            วันที่สิ้นสุด
            <input type="date" name="endDate" value="<%= filters.endDate %>">
          </label>
          <label>
            แนวโน้ม
            <select name="granularity">
              <option value="day" <%= filters.granularity === 'day' ? 'selected' : '' %>>รายวัน</option>
              <option value="month" <%= filters.granularity === 'month' ? 'selected' : '' %>>รายเดือน</option>
            </select>
          </label>
          <div class="filter-actions">
            <button type="submit" class="primary-button"><i class="bi bi-funnel"></i> แสดงผล</button>
            <a class="secondary-button" href="/executive/export.pdf?startDate=<%= filters.startDate %>&endDate=<%= filters.endDate %>&granularity=<%= filters.granularity %>">
              <i class="bi bi-filetype-pdf"></i>
              Export PDF
            </a>
          </div>
        </form>
      </section>

      <section class="executive-kpis">
        <article class="executive-kpi primary"><p>Total Telemed</p><strong><%= data.total.toLocaleString('th-TH') %></strong></article>
        <article class="executive-kpi"><p>DM รวม</p><strong><%= metrics.dm.toLocaleString('th-TH') %></strong></article>
        <article class="executive-kpi"><p>HT รวม</p><strong><%= metrics.ht.toLocaleString('th-TH') %></strong></article>
        <article class="executive-kpi"><p>B2B รวม</p><strong><%= metrics.b2b.toLocaleString('th-TH') %></strong></article>
        <article class="executive-kpi"><p>B2C รวม</p><strong><%= metrics.b2c.toLocaleString('th-TH') %></strong></article>
        <article class="executive-kpi"><p>B2B / B2C</p><strong><%= metrics.b2bPercent.toFixed(1) %>% / <%= metrics.b2cPercent.toFixed(1) %>%</strong></article>
      </section>

      <section class="panel executive-summary">
        <h2>Executive Summary</h2>
        <p><%= metrics.summary %></p>
      </section>

      <section class="dashboard-grid executive-charts">
        <article class="panel wide">
          <div class="panel-heading">
            <h2>แนวโน้ม Telemed</h2>
            <span><%= filters.startDate %> ถึง <%= filters.endDate %></span>
          </div>
          <canvas id="execTrendChart" height="120"></canvas>
        </article>
        <article class="panel">
          <div class="panel-heading">
            <h2>B2B vs B2C</h2>
          </div>
          <canvas id="execChannelChart" height="210"></canvas>
        </article>
        <article class="panel">
          <div class="panel-heading">
            <h2>DM vs HT</h2>
          </div>
          <canvas id="execDiseaseChart" height="210"></canvas>
        </article>
      </section>
    </main>
  </div>

  <div id="executivePayload" hidden><%= JSON.stringify({ metrics, channel: data.channel }) %></div>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="/js/executive.js"></script>
</body>
</html>

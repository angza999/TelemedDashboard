<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Telemed Dashboard</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css?v=executive-action-focus-1">
</head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar', { active: 'executive' }) %>

    <main class="main executive-main">
      <header class="topbar">
        <div>
          <p class="eyebrow">ภาพรวมสำหรับผู้บริหาร</p>
          <h1>Executive Dashboard</h1>
        </div>
        <% if (currentUser) { %>
          <form action="/logout" method="post" class="user-box">
            <span><i class="bi bi-person-circle"></i> <%= currentUser.name %></span>
            <button type="submit" class="icon-button" title="ออกจากระบบ" aria-label="ออกจากระบบ">
              <i class="bi bi-box-arrow-right"></i>
            </button>
          </form>
        <% } %>
      </header>

      <div class="executive-tabs" role="tablist" aria-label="Executive Dashboard tabs">
        <button type="button" class="tab-button <%= activeTab === 'overview' ? 'active' : '' %>" data-exec-tab="overview">ภาพรวมผู้บริหาร</button>
        <button type="button" class="tab-button <%= activeTab === 'department-target' ? 'active' : '' %>" data-exec-tab="department-target">เป้าหมายรายห้อง</button>
      </div>

      <section class="tab-panel <%= activeTab === 'overview' ? 'active' : '' %>" data-exec-panel="overview">
        <section class="filter-panel">
          <% if (dbError) { %>
            <div class="alert db-alert"><strong><%= dbError %></strong></div>
          <% } %>
          <form action="/executive" method="get" class="filter-grid executive-filter">
            <input type="hidden" name="tab" value="overview">
            <label>
              วันที่เริ่มต้น
              <input type="date" name="startDate" value="<%= filters.startDate %>">
            </label>
            <label>
              วันที่สิ้นสุด
              <input type="date" name="endDate" value="<%= filters.endDate %>">
            </label>
            <label>
              แนวโน้ม
              <select name="granularity">
                <option value="day" <%= filters.granularity === 'day' ? 'selected' : '' %>>รายวัน</option>
                <option value="month" <%= filters.granularity === 'month' ? 'selected' : '' %>>รายเดือน</option>
              </select>
            </label>
            <div class="filter-actions">
              <button type="submit" class="primary-button"><i class="bi bi-funnel"></i> แสดงผล</button>
              <a class="secondary-button" href="/executive/export.pdf?startDate=<%= filters.startDate %>&endDate=<%= filters.endDate %>&granularity=<%= filters.granularity %>">
                <i class="bi bi-filetype-pdf"></i>
                Export PDF
              </a>
            </div>
          </form>
        </section>

        <section class="executive-kpis">
          <article class="executive-kpi primary"><p>Total Telemed</p><strong><%= data.total.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi"><p>DM รวม</p><strong><%= metrics.dm.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi"><p>HT รวม</p><strong><%= metrics.ht.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi"><p>B2B รวม</p><strong><%= metrics.b2b.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi"><p>B2C รวม</p><strong><%= metrics.b2c.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi"><p>B2B / B2C</p><strong><%= metrics.b2bPercent.toFixed(1) %>% / <%= metrics.b2cPercent.toFixed(1) %>%</strong></article>
        </section>

        <section class="panel executive-summary">
          <h2>Executive Summary</h2>
          <p><%= metrics.summary %></p>
        </section>

        <section class="dashboard-grid executive-charts">
          <article class="panel wide">
            <div class="panel-heading">
              <h2>แนวโน้ม Telemed</h2>
              <span><%= filters.startDate %> ถึง <%= filters.endDate %></span>
            </div>
            <canvas id="execTrendChart" height="120"></canvas>
          </article>
          <article class="panel">
            <div class="panel-heading">
              <h2>B2B vs B2C</h2>
            </div>
            <canvas id="execChannelChart" height="210"></canvas>
          </article>
          <article class="panel">
            <div class="panel-heading">
              <h2>DM vs HT</h2>
            </div>
            <canvas id="execDiseaseChart" height="210"></canvas>
          </article>
        </section>
      </section>

      <section class="tab-panel <%= activeTab === 'department-target' ? 'active' : '' %>" data-exec-panel="department-target">
        <section class="filter-panel">
          <% if (dbError || targetError) { %>
            <div class="alert db-alert"><strong><%= targetError || dbError %></strong></div>
          <% } %>
          <div class="panel-note target-intro">
            หน้านี้ใช้ติดตามจำนวน Telemed ของแต่ละห้องส่งตรวจ เทียบกับเป้าหมาย 50% ของจำนวนผู้รับบริการ OPD ในช่วงวันที่ที่เลือก
          </div>
          <% if (target.rows.length > 0 && !target.hasB2b) { %>
            <div class="data-quality-note">
              <i class="bi bi-info-circle"></i>
              <span>ข้อสังเกตข้อมูล: ยังไม่พบ B2B ในช่วงวันที่นี้ ตรวจสอบคำว่า B2B ใน ovstist.name หรือ opdscreen.cc หากคาดว่าควรมีข้อมูล</span>
            </div>
          <% } %>
          <form action="/executive" method="get" class="filter-grid department-target-filter">
            <input type="hidden" name="tab" value="department-target">
            <label>
              วันที่เริ่มต้น
              <input type="date" name="startDate" value="<%= filters.startDate %>">
            </label>
            <label>
              วันที่สิ้นสุด
              <input type="date" name="endDate" value="<%= filters.endDate %>">
            </label>
            <label>
              เลือกห้องส่งตรวจ
              <select name="depcode">
                <option value="all" <%= targetFilters.depcode === 'all' ? 'selected' : '' %>>ทั้งหมด</option>
                <% target.departments.forEach((department) => { %>
                  <option value="<%= department.depcode %>" <%= targetFilters.depcode === department.depcode ? 'selected' : '' %>><%= department.department %></option>
                <% }) %>
              </select>
            </label>
            <label>
              สถานะ
              <select name="status">
                <option value="all" <%= targetFilters.status === 'all' ? 'selected' : '' %>>ทั้งหมด</option>
                <option value="passed" <%= targetFilters.status === 'passed' ? 'selected' : '' %>>ผ่านเป้าหมาย</option>
                <option value="failed" <%= targetFilters.status === 'failed' ? 'selected' : '' %>>ยังไม่ถึงเป้าหมาย</option>
              </select>
            </label>
            <label>
              การเรียงลำดับ
              <select name="sortBy">
                <option value="target_gap" <%= targetFilters.sortBy === 'target_gap' ? 'selected' : '' %>>ขาดเป้าหมายมากสุด</option>
                <option value="percent_low" <%= targetFilters.sortBy === 'percent_low' ? 'selected' : '' %>>% ต่ำสุด</option>
                <option value="telemed_desc" <%= targetFilters.sortBy === 'telemed_desc' ? 'selected' : '' %>>Telemed มากสุด</option>
                <option value="opd_desc" <%= targetFilters.sortBy === 'opd_desc' ? 'selected' : '' %>>OPD มากสุด</option>
              </select>
            </label>
            <div class="filter-actions">
              <button type="submit" class="primary-button"><i class="bi bi-funnel"></i> แสดงผล</button>
              <a class="secondary-button" href="/executive/department-target.xlsx?startDate=<%= filters.startDate %>&endDate=<%= filters.endDate %>&depcode=<%= targetFilters.depcode %>&status=<%= targetFilters.status %>&sortBy=<%= targetFilters.sortBy %>">
                <i class="bi bi-file-earmark-excel"></i>
                Export Excel
              </a>
            </div>
          </form>
        </section>

        <%
          const targetGap = Number(target.summary.diff_from_target || 0);
          const targetGapAbs = Math.abs(targetGap);
          const worstDepartment = target.summary.worst_department;
          const topFailedDepartments = target.summary.top_failed_departments || [];
          const followUpRooms = topFailedDepartments.map((row) => row.department).join(', ');
          const targetGoalPercent = target.summary.target_50_total > 0
            ? (target.summary.telemed_total / target.summary.target_50_total) * 100
            : 0;
          const targetGoalProgress = Math.min(targetGoalPercent, 100);
          const targetPercentGap = Math.max(0, 50 - Number(target.summary.telemed_percent || 0));
          const topActionRooms = topFailedDepartments.slice(0, 3);
          let targetExecutiveSummary = 'ไม่พบข้อมูลในช่วงวันที่ที่เลือก';
          if (target.rows.length > 0) {
            targetExecutiveSummary = `ช่วงวันที่ ${filters.startDate} - ${filters.endDate} มี OPD รวม ${target.summary.opd_total.toLocaleString('th-TH')} ราย มี Telemed รวม ${target.summary.telemed_total.toLocaleString('th-TH')} ราย คิดเป็น ${target.summary.telemed_percent.toFixed(2)}% ของ OPD ทั้งหมด เป้าหมาย 50% คือ ${target.summary.target_50_total.toLocaleString('th-TH')} ราย `;
            targetExecutiveSummary += targetGap < 0
              ? `ยังขาดเป้าหมาย ${targetGapAbs.toLocaleString('th-TH')} ราย`
              : 'ถึงเป้าหมายแล้ว';
            if (followUpRooms) {
              targetExecutiveSummary += ` ห้องที่ควรติดตามเร่งด่วน ได้แก่ ${followUpRooms}`;
            }
          }
        %>

        <section class="panel action-required-panel">
          <div>
            <p class="eyebrow">Action Required</p>
            <h2><%= targetGap < 0 ? `ยังขาดเป้าหมาย ${targetGapAbs.toLocaleString('th-TH')} ราย` : 'ถึงเป้าหมายรวมแล้ว' %></h2>
            <p>
              ทำได้จริง <strong><%= target.summary.telemed_percent.toFixed(2) %>%</strong> จากเป้าหมาย 50%
              <% if (targetPercentGap > 0) { %>
                ยังต่ำกว่าเป้า <strong><%= targetPercentGap.toFixed(2) %> จุด</strong>
              <% } %>
            </p>
          </div>
          <div class="action-room-list">
            <% if (topActionRooms.length > 0) { %>
              <% topActionRooms.forEach((row) => { %>
                <span><%= row.department %> <strong>ขาด <%= Math.abs(row.diff_from_target).toLocaleString('th-TH') %></strong></span>
              <% }) %>
            <% } else { %>
              <span><strong>ไม่มีห้องที่ขาดเป้าหมาย</strong></span>
            <% } %>
          </div>
        </section>

        <section class="panel target-executive-summary">
          <div class="panel-heading">
            <h2>Executive Summary</h2>
          </div>
          <p><%= targetExecutiveSummary %></p>
        </section>

        <section class="panel target-overall-progress">
          <div class="panel-heading">
            <div>
              <h2>ความคืบหน้าเป้าหมายรวม</h2>
              <p class="panel-note">Telemed รวม <%= target.summary.telemed_total.toLocaleString('th-TH') %> / เป้าหมาย <%= target.summary.target_50_total.toLocaleString('th-TH') %> ราย</p>
            </div>
            <strong><%= targetGoalPercent.toFixed(2) %>%</strong>
          </div>
          <div class="overall-progress-track" aria-hidden="true">
            <span class="overall-progress-fill <%= targetGap < 0 ? 'behind' : 'passed' %>" style="width: <%= targetGoalProgress.toFixed(2) %>%"></span>
          </div>
          <div class="overall-progress-meta">
            <span>เริ่มต้น</span>
            <span>เป้าหมาย 100%</span>
          </div>
        </section>

        <section class="executive-kpis target-kpis">
          <article class="executive-kpi"><p>OPD รวม</p><strong><%= target.summary.opd_total.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi"><p>Telemed รวม</p><strong><%= target.summary.telemed_total.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi"><p>เป้าหมาย 50%</p><strong><%= target.summary.target_50_total.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi">
            <p>ทำได้จริง</p>
            <strong><%= target.summary.telemed_percent.toFixed(2) %>%</strong>
            <span>จากเป้าหมาย 50%</span>
          </article>
          <article class="executive-kpi primary target-gap-kpi <%= targetGap < 0 ? 'behind' : 'passed' %>">
            <p><%= targetGap < 0 ? 'ขาดเป้ารวม' : 'เกินเป้ารวม' %></p>
            <strong><%= targetGap < 0 ? `ขาด ${targetGapAbs.toLocaleString('th-TH')}` : (targetGap > 0 ? `+${targetGap.toLocaleString('th-TH')}` : 'ถึงเป้าหมายแล้ว') %></strong>
            <% if (targetGap !== 0) { %><span>ราย</span><% } %>
          </article>
          <article class="executive-kpi"><p>ผ่านเป้า</p><strong><%= target.summary.passed_department_count.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi"><p>ยังไม่ผ่าน</p><strong><%= target.summary.failed_department_count.toLocaleString('th-TH') %></strong></article>
          <article class="executive-kpi worst-gap-kpi">
            <p>ขาดมากที่สุด</p>
            <% if (worstDepartment) { %>
              <strong><%= worstDepartment.department %></strong>
              <span>ขาด <%= Math.abs(worstDepartment.diff_from_target).toLocaleString('th-TH') %> ราย</span>
            <% } else { %>
              <strong>ไม่มีห้องที่ขาดเป้า</strong>
            <% } %>
          </article>
        </section>

        <section class="panel urgent-followup-panel">
          <div class="panel-heading">
            <div>
              <h2>ต้องติดตามวันนี้</h2>
              <p class="panel-note">Top 5 ห้องที่ขาดเป้าหมายมากที่สุด</p>
            </div>
          </div>
          <div class="shortage-list priority-list">
            <% target.rows.filter((row) => row.diff_from_target < 0).slice(0, 5).forEach((row, index) => { %>
              <div class="shortage-item priority-item">
                <span><strong><%= index + 1 %>.</strong> <%= row.department %></span>
                <strong>ขาด <%= Math.abs(row.diff_from_target).toLocaleString('th-TH') %> ราย</strong>
                <small>ทำได้ <%= Number(row.telemed_percent || 0).toFixed(2) %>% | Telemed <%= row.telemed_total.toLocaleString('th-TH') %> ราย</small>
              </div>
            <% }) %>
            <% if (!target.rows.some((row) => row.diff_from_target < 0)) { %>
              <p class="panel-note">ไม่มีห้องที่ขาดเป้าหมายในช่วงวันที่นี้</p>
            <% } %>
          </div>
        </section>

        <section class="dashboard-grid executive-charts target-charts">
          <article class="panel wide">
            <div class="panel-heading">
              <h2>Telemed เทียบเป้าหมายรายห้อง</h2>
              <div class="chart-limit-toggle" aria-label="เลือกจำนวนห้องในกราฟ">
                <button type="button" class="chart-limit-button active" data-target-chart-limit="10">Top 10</button>
                <button type="button" class="chart-limit-button" data-target-chart-limit="20">Top 20</button>
                <button type="button" class="chart-limit-button" data-target-chart-limit="all">ทั้งหมด</button>
              </div>
            </div>
            <div class="target-chart-canvas-wrap">
              <canvas id="departmentTargetChart"></canvas>
            </div>
          </article>
          <article class="panel wide">
            <div class="panel-heading">
              <h2>ขาดเป้าหมายรายห้อง</h2>
              <span>จำนวนรายที่ต้องเพิ่มเพื่อถึงเป้าหมาย 50%</span>
            </div>
            <div class="target-chart-canvas-wrap">
              <canvas id="departmentPercentChart"></canvas>
            </div>
          </article>
        </section>

        <section class="panel table-panel">
          <div class="panel-heading">
            <div>
              <h2>ติดตามเป้าหมาย Telemed รายห้อง</h2>
              <p class="panel-note">เรียงห้องที่ยังไม่ถึงเป้าหมายและขาดเป้าหมายมากที่สุดก่อน</p>
            </div>
            <div class="table-view-toggle target-table-toggle" aria-label="เลือกมุมมองตารางเป้าหมายรายห้อง">
              <button type="button" class="table-view-button active" data-target-table-view="summary">ผู้บริหาร</button>
              <button type="button" class="table-view-button" data-target-table-view="detail">รายละเอียด</button>
            </div>
          </div>
          <div class="table-wrap department-target-table-wrap">
            <table class="department-target-table summary-mode">
              <thead>
                <tr>
                  <th>ลำดับ</th>
                  <th class="target-detail-column">รหัสห้อง</th>
                  <th>ห้องส่งตรวจ</th>
                  <th>OPD ทั้งหมด</th>
                  <th>Telemed ทั้งหมด</th>
                  <th class="target-detail-column">B2B</th>
                  <th class="target-detail-column">B2C</th>
                  <th class="target-detail-column">เป้าหมาย 50%</th>
                  <th>ทำได้ %</th>
                  <th>ต้องเพิ่ม/เกินเป้า</th>
                  <th>สถานะ</th>
                </tr>
              </thead>
              <tbody>
                <% if (target.rows.length === 0) { %>
                  <tr><td colspan="11" class="empty">ไม่พบข้อมูลในช่วงวันที่ที่เลือก</td></tr>
                <% } %>
                <% target.rows.forEach((row, index) => { %>
                  <tr class="<%= row.target_status === 'ยังไม่ถึงเป้าหมาย' ? 'target-row-failed' : '' %>">
                    <td><%= index + 1 %></td>
                    <td class="target-detail-column"><%= row.depcode %></td>
                    <td><%= row.department %></td>
                    <td><%= row.opd_total.toLocaleString('th-TH') %></td>
                    <td><%= row.telemed_total.toLocaleString('th-TH') %></td>
                    <td class="target-detail-column"><%= row.b2b_total.toLocaleString('th-TH') %></td>
                    <td class="target-detail-column"><%= row.b2c_total.toLocaleString('th-TH') %></td>
                    <td class="target-detail-column"><%= row.target_50.toLocaleString('th-TH') %></td>
                    <td>
                      <div class="target-progress-cell">
                        <strong><%= row.telemed_percent.toFixed(2) %>%</strong>
                        <div class="target-progress-track" aria-hidden="true">
                          <span class="target-progress-fill <%= row.telemed_percent >= 50 ? 'passed' : (row.telemed_percent >= 45 ? 'near' : 'failed') %>" style="width: <%= Math.min(row.telemed_percent, 100).toFixed(2) %>%"></span>
                        </div>
                      </div>
                    </td>
                    <td><%= row.diff_from_target < 0 ? `ต้องเพิ่ม ${Math.abs(row.diff_from_target).toLocaleString('th-TH')}` : `เกิน ${row.diff_from_target.toLocaleString('th-TH')}` %></td>
                    <td>
                      <span class="target-status <%= row.telemed_total >= row.target_50 ? 'passed' : (row.telemed_percent >= 45 ? 'near' : 'failed') %>">
                        <%= row.target_status %>
                      </span>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
              <% if (target.rows.length > 0) { %>
                <tfoot>
                  <tr>
                    <th>รวม</th>
                    <th class="target-detail-column"></th>
                    <th>ทั้งหมด</th>
                    <th><%= target.summary.opd_total.toLocaleString('th-TH') %></th>
                    <th><%= target.summary.telemed_total.toLocaleString('th-TH') %></th>
                    <th class="target-detail-column"><%= target.summary.b2b_total.toLocaleString('th-TH') %></th>
                    <th class="target-detail-column"><%= target.summary.b2c_total.toLocaleString('th-TH') %></th>
                    <th class="target-detail-column"><%= target.summary.target_50_total.toLocaleString('th-TH') %></th>
                    <th>
                      <div class="target-progress-cell total">
                        <strong><%= target.summary.telemed_percent.toFixed(2) %>%</strong>
                        <div class="target-progress-track" aria-hidden="true">
                          <span class="target-progress-fill <%= target.summary.telemed_percent >= 50 ? 'passed' : (target.summary.telemed_percent >= 45 ? 'near' : 'failed') %>" style="width: <%= Math.min(target.summary.telemed_percent, 100).toFixed(2) %>%"></span>
                        </div>
                      </div>
                    </th>
                    <th><%= target.summary.diff_from_target < 0 ? `ต้องเพิ่ม ${Math.abs(target.summary.diff_from_target).toLocaleString('th-TH')}` : `เกิน ${target.summary.diff_from_target.toLocaleString('th-TH')}` %></th>
                    <th></th>
                  </tr>
                </tfoot>
              <% } %>
            </table>
          </div>
        </section>
      </section>
    </main>
  </div>

  <div id="executivePayload" hidden><%= JSON.stringify({ metrics, channel: data.channel, target }) %></div>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="/js/executive.js?v=executive-chart-label-1"></script>
</body>
</html>
